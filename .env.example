# OpenAI-compatible base URL for the ClosedMesh runtime.
# Default: the closedmesh runtime running locally in --private-only mode.
CLOSEDMESH_RUNTIME_URL=http://127.0.0.1:9337/v1

# ClosedMesh admin port (used to look up node / topology info).
CLOSEDMESH_ADMIN_URL=http://127.0.0.1:3131

# Optional: pin the model id used by /api/chat. If unset, the API picks
# the first model returned by /v1/models.
# CLOSEDMESH_MODEL=Qwen3-8B-Q4_K_M

# Optional: hard-code the path to the closedmesh binary (used by /control).
# If unset, the API auto-detects from $PATH and standard install dirs.
# CLOSEDMESH_BIN=/Users/me/.local/bin/closedmesh

# Set NEXT_PUBLIC_DEPLOYMENT=public on the Vercel-hosted deployment so the
# /control page disables itself there (the controller only makes sense locally).
# NEXT_PUBLIC_DEPLOYMENT=public

# Origins allowed to call this controller's /api/chat and /api/status from
# the browser (comma-separated). Default: https://closedmesh.com. The hosted
# closedmesh.com page calls back into the visitor's local controller running
# at http://localhost:3000, and that cross-origin call needs CORS to be set
# up here. For local development against a non-default origin, e.g.
#   CLOSEDMESH_PUBLIC_ORIGINS=https://closedmesh.com,http://localhost:3001
# CLOSEDMESH_PUBLIC_ORIGINS=https://closedmesh.com

# Where the browser-side chat client should send /api/chat when running on
# https://closedmesh.com. Defaults to http://localhost:3000 (the local
# controller installed by scripts/install-controller.sh). Mostly useful for
# testing alternate ports.
# NEXT_PUBLIC_LOCAL_CONTROLLER_URL=http://localhost:3000

# Deprecated fallbacks (still honored for one release): MESH_LLM_URL,
# MESH_CONSOLE_URL, MESH_LLM_MODEL, FORGEMESH_BIN.
