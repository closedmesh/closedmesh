# OpenAI-compatible base URL for the ClosedMesh runtime.
#
# Two common shapes:
#   - Local dev / desktop .app talking to a local closedmesh CLI:
#       CLOSEDMESH_RUNTIME_URL=http://127.0.0.1:9337/v1
#   - Vercel deployment (closedmesh.com) or a desktop .app pointed at
#     the public mesh entry point (Caddy + auth gateway):
#       CLOSEDMESH_RUNTIME_URL=https://mesh.closedmesh.com/v1
#
# Default if unset: http://127.0.0.1:9337/v1.
CLOSEDMESH_RUNTIME_URL=http://127.0.0.1:9337/v1

# ClosedMesh admin port (used to look up node / topology info).
# For the public deployment, point this at the same gateway:
#   CLOSEDMESH_ADMIN_URL=https://mesh.closedmesh.com
CLOSEDMESH_ADMIN_URL=http://127.0.0.1:3131

# Bearer token shared with the runtime's auth gateway (Caddy in front of
# the public mesh). Set on Vercel for the closedmesh.com deployment so
# /api/chat and /api/status authenticate to mesh.closedmesh.com. Leave
# unset in local dev where the runtime is on the loopback.
# CLOSEDMESH_RUNTIME_TOKEN=...

# Optional: pin the model id used by /api/chat. If unset, the API picks
# the first model returned by /v1/models.
# CLOSEDMESH_MODEL=Qwen3-8B-Q4_K_M

# Optional: hard-code the path to the closedmesh binary (used by /control).
# If unset, the API auto-detects from $PATH and standard install dirs.
# CLOSEDMESH_BIN=/Users/me/.local/bin/closedmesh

# Set NEXT_PUBLIC_DEPLOYMENT=public on the Vercel-hosted deployment so the
# /control page disables itself there (the controller only makes sense
# locally, since it spawns the closedmesh CLI).
# NEXT_PUBLIC_DEPLOYMENT=public

# Origins allowed to call this controller's /api/chat and /api/status
# from the browser (comma-separated). Default: https://closedmesh.com.
# Used by legacy installs where the public site calls back into a local
# controller running at http://localhost:3000. The current architecture
# (post-Phase 8b) keeps all fetches same-origin so this matters less,
# but the CORS layer is still wired up for backward compatibility.
# CLOSEDMESH_PUBLIC_ORIGINS=https://closedmesh.com

# Where the browser-side chat client should send /api/chat when running
# on https://closedmesh.com. Defaults to http://localhost:3000 (the
# legacy local controller). The current Vercel deployment proxies via
# its own same-origin /api/chat instead, so this is only relevant if
# you re-enable the cross-origin path.
# NEXT_PUBLIC_LOCAL_CONTROLLER_URL=http://localhost:3000

# Deprecated fallbacks (still honored for one release): MESH_LLM_URL,
# MESH_CONSOLE_URL, MESH_LLM_MODEL, FORGEMESH_BIN.
