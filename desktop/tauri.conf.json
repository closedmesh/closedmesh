{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ClosedMesh",
  "version": "0.1.2",
  "identifier": "dev.closedmesh.shell",
  "build": {
    "frontendDist": "dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    },
    "withGlobalTauri": false
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "Private LLM mesh.",
    "longDescription": "ClosedMesh runs your team's chat on hardware you own — no cloud LLM API, no data leaving the network you control. This is the desktop shell; the runtime ships separately as the `closedmesh` CLI.",
    "copyright": "Apache-2.0 / MIT",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "sidecar/binaries/node"
    ],
    "resources": [
      "sidecar/controller"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0",
      "signingIdentity": "-",
      "entitlements": "macos/sidecar.entitlements.plist"
    },
    "windows": {
      "wix": {
        "language": "en-US"
      }
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"]
      }
    }
  },
  "plugins": {}
}
