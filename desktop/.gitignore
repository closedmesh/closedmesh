# Cargo build artifacts (Cargo.lock is committed -- binary crate)
target/

# Tauri-generated capability schemas, mobile project scaffolding, etc.
gen/

# npm
node_modules/

# Generated on every build. `icons/source.svg` is the design source-of-truth;
# everything else is rasterized by `scripts/svg-to-png.mjs` + `tauri icon`
# and only needs to live in release artifacts, not git.
icons/*
!icons/source.svg

# Bundled Next.js controller + Node.js binaries (Phase 8b sidecar). Both are
# regenerated by desktop/scripts/{stage-controller,fetch-node}.sh during
# `tauri build`, so checking them in would just bloat the repo with bytes
# we already produce reproducibly. The sidecar/ folder itself stays
# (with .gitkeep + README.md) so `tauri build` never trips on a missing dir.
sidecar/controller/
sidecar/binaries/
